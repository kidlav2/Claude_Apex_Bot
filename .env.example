# ─── Binance API credentials ────────────────────────────────────────────────
# Get these from: Binance account → API Management
# Withdrawals: OFF. IP whitelist: ON (server IP only).

# Spot keys (used when BINANCE_FUTURES=false)
BINANCE_API_KEY=your_spot_api_key_here
BINANCE_SECRET_KEY=your_spot_secret_key_here

# Futures keys (used when BINANCE_FUTURES=true). Permission: Enable Futures
BINANCE_FUTURES_API_KEY=your_futures_api_key_here
BINANCE_FUTURES_API_SECRET_KEY=your_futures_secret_key_here

# ─── Mode toggles ───────────────────────────────────────────────────────────
# PAPER_TRADING=true → no real orders, decisions logged only
# PAPER_TRADING=false → REAL ORDERS placed on the exchange
PAPER_TRADING=false

# BINANCE_FUTURES=true → trade USDS-M futures (allows shorts, leverage)
# BINANCE_FUTURES=false → spot only (long only, no leverage)
BINANCE_FUTURES=true

# Leverage (futures only). 1 = same risk as spot, no liquidation pressure.
# 2 = double notional per margin unit, half the buffer to liquidation.
LEVERAGE=2
MARGIN_TYPE=ISOLATED

# ─── Trading config ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=50
# Aggregate notional cap across all open positions (futures). Bot blocks new
# entries that would push total exposure above this. Lets 3–4 simultaneous
# $50 positions coexist; tighten if you want fewer concurrent trades.
TOTAL_EXPOSURE_LIMIT=180
MAX_TRADES_PER_DAY=5
MIN_MINUTES_LEFT_TO_ENTRY=25
# Take-profit multiple of risk (RR). 1.5 = TP at 1.5× the SL distance from
# entry. Lower for higher fill rate within Kill Zone, higher for fatter wins.
RR_RATIO=1.5
# Hard time stop at kill-zone end is *conditional* (Variant B): if uPnL > 0
# the position is left running under its existing OCO bracket so the edge
# can play out past 60 min. MAX_HOLD_HOURS is the absolute backstop — any
# position older than this is force-closed regardless of uPnL, preventing
# a stuck winner from drifting into the next session/overnight.
MAX_HOLD_HOURS=4

# Trailing SL profit-lock fraction (M2). After the position is past BE, each
# tick recomputes the trail target at entry + this_fraction × unrealized_profit
# and moves SL there if it improves on current. 0.5 = lock half the gain.
# At 2R, SL locks 1R; at 3R, locks 1.5R. Set to 0 to disable trailing.
TRAIL_PROFIT_FRACTION=0.5

# Funding-rate skip thresholds (H4). Two-stage gate:
#   "Far" — sign-blind cap on extreme imbalance, blocks at any time.
#   "Near" — kicks in only if settlement is within SKIP_FUNDING_NEAR_MIN
#            minutes AND the position direction would PAY the funding.
# Long with positive rate pays at settlement; short with positive rate
# receives. Receiving never blocks.
SKIP_HIGH_FUNDING_RATE=0.001
SKIP_FUNDING_NEAR_MIN=15
SKIP_FUNDING_NEAR_RATE=0.0003

# Daily drawdown circuit-breaker (H12). Realized + unrealized PnL below this
# percent of portfolio stops all trading for the day. 5 = -5% of portfolio.
MAX_DAILY_DD_PCT=5

# HTTP timeout for Binance API calls (ms). 10s is comfortable margin over
# typical ~100ms latency but tight enough to detect outages before the next
# cron tick.
BINANCE_FETCH_TIMEOUT_MS=10000

# ─── Symbol / timeframe ─────────────────────────────────────────────────────
SYMBOL=BTCUSDT
TIMEFRAME=15m

# ─── Telegram alerts ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Dynamic Screener ──────────────────────────────────────────────────────
# When true, watchlist is rebuilt at the start of each Kill Zone from the
# top USDT-perpetuals by 4h volatility (with liquidity + funding gates).
# Set to false to fall back to the static rules.json watchlist.
DYNAMIC_SCREENER=true
SCREENER_MIN_VOLUME=75000000
SCREENER_MAX_DAILY_CHANGE=12
# Last-price floor (USDT) — sub-cent meme tokens excluded by default. Bump
# to 0.1 for a stricter filter that keeps only mid-cap+ pairs.
SCREENER_MIN_PRICE=0.01
SCREENER_VOL_TOP=7
SCREENER_VOL_BARS=16
SCREENER_MAX_FUNDING=0.001
SCREENER_ANCHORS=BTCUSDT,ETHUSDT
SCREENER_BLOCKLIST=
