# ─── Binance API credentials ────────────────────────────────────────────────
# Get these from: Binance account → API Management
# Withdrawals: OFF. IP whitelist: ON (server IP only).

# Spot keys (used when BINANCE_FUTURES=false)
BINANCE_API_KEY=your_spot_api_key_here
BINANCE_SECRET_KEY=your_spot_secret_key_here

# Futures keys (used when BINANCE_FUTURES=true). Permission: Enable Futures
BINANCE_FUTURES_API_KEY=your_futures_api_key_here
BINANCE_FUTURES_API_SECRET_KEY=your_futures_secret_key_here

# ─── Mode toggles ───────────────────────────────────────────────────────────
# PAPER_TRADING=true → no real orders, decisions logged only
# PAPER_TRADING=false → REAL ORDERS placed on the exchange
PAPER_TRADING=false

# BINANCE_FUTURES=true → trade USDS-M futures (allows shorts, leverage)
# BINANCE_FUTURES=false → spot only (long only, no leverage)
BINANCE_FUTURES=true

# Leverage (futures only). 1 = same risk as spot, no liquidation pressure.
LEVERAGE=1
MARGIN_TYPE=ISOLATED

# ─── Trading config ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=100
MAX_TRADES_PER_DAY=5
MIN_MINUTES_LEFT_TO_ENTRY=25

# Skip funding spikes (fraction per 8h, 0.001 = 0.1%)
SKIP_HIGH_FUNDING_RATE=0.001

# ─── Symbol / timeframe ─────────────────────────────────────────────────────
SYMBOL=BTCUSDT
TIMEFRAME=15m

# ─── Telegram alerts ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
