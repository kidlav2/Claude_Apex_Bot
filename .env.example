# ─── Binance API credentials ────────────────────────────────────────────────
# Get these from: Binance account → API Management
# Withdrawals: OFF. IP whitelist: ON (server IP only).

# Spot keys (used when BINANCE_FUTURES=false)
BINANCE_API_KEY=your_spot_api_key_here
BINANCE_SECRET_KEY=your_spot_secret_key_here

# Futures keys (used when BINANCE_FUTURES=true). Permission: Enable Futures
BINANCE_FUTURES_API_KEY=your_futures_api_key_here
BINANCE_FUTURES_API_SECRET_KEY=your_futures_secret_key_here

# ─── Mode toggles ───────────────────────────────────────────────────────────
# PAPER_TRADING=true → no real orders, decisions logged only
# PAPER_TRADING=false → REAL ORDERS placed on the exchange
PAPER_TRADING=false

# BINANCE_FUTURES=true → trade USDS-M futures (allows shorts, leverage)
# BINANCE_FUTURES=false → spot only (long only, no leverage)
BINANCE_FUTURES=true

# Leverage (futures only). 1 = same risk as spot, no liquidation pressure.
# 2 = double notional per margin unit, half the buffer to liquidation.
LEVERAGE=2
MARGIN_TYPE=ISOLATED

# ─── Trading config ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=50
# Aggregate notional cap across all open positions (futures). Bot blocks new
# entries that would push total exposure above this. Lets 3–4 simultaneous
# $50 positions coexist; tighten if you want fewer concurrent trades.
TOTAL_EXPOSURE_LIMIT=180
MAX_TRADES_PER_DAY=5
MIN_MINUTES_LEFT_TO_ENTRY=25
# Take-profit multiple of risk (RR). 1.5 = TP at 1.5× the SL distance from
# entry. Lower for higher fill rate within Kill Zone, higher for fatter wins.
RR_RATIO=1.5

# Skip funding spikes (fraction per 8h, 0.001 = 0.1%)
SKIP_HIGH_FUNDING_RATE=0.001

# ─── Symbol / timeframe ─────────────────────────────────────────────────────
SYMBOL=BTCUSDT
TIMEFRAME=15m

# ─── Telegram alerts ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Dynamic Screener ──────────────────────────────────────────────────────
# When true, watchlist is rebuilt at the start of each Kill Zone from the
# top USDT-perpetuals by 4h volatility (with liquidity + funding gates).
# Set to false to fall back to the static rules.json watchlist.
DYNAMIC_SCREENER=true
SCREENER_MIN_VOLUME=75000000
SCREENER_MAX_DAILY_CHANGE=12
SCREENER_VOL_TOP=7
SCREENER_VOL_BARS=16
SCREENER_MAX_FUNDING=0.001
SCREENER_ANCHORS=BTCUSDT,ETHUSDT
SCREENER_BLOCKLIST=
